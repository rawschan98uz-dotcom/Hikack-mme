# Hi Jack LMS — production / cloud deployment
# Copy to .env on Render/Railway or set in dashboard.

# Required in production
SECRET_KEY=change-me-to-long-random-string
DEBUG=false
ALLOWED_HOSTS=.onrender.com,your-app.up.railway.app,lms.company.uz

# PostgreSQL (Render/Railway inject automatically when DB is linked)
DATABASE_URL=postgresql://user:pass@host:5432/hijack_lms
DATABASE_SSL=true

# First deploy only — demo users (CEO, Teacher, etc.)
SEED_DEMO=1

# Optional — comma-separated origins for Django admin CSRF
CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com,https://lms.company.uz

# Local dev only (leave DATABASE_URL empty to use SQLite)
# DEBUG=true
# ALLOWED_HOSTS=*
